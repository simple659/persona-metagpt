# persona-metagpt 配置文件
# 复制此文件为 config.yaml 并填入你的 API Key

llm:
  # ── 选项1：OpenAI（默认）──
  api_type: "openai"
  model: "gpt-4-turbo"
  base_url: "https://api.openai.com/v1"
  api_key: "YOUR_OPENAI_API_KEY"

  # ── 选项2：DeepSeek（国内推荐，性价比高）──
  # api_type: "openai"
  # model: "deepseek-chat"
  # base_url: "https://api.deepseek.com/v1"
  # api_key: "YOUR_DEEPSEEK_API_KEY"

  # ── 选项3：通义千问 ──
  # api_type: "openai"
  # model: "qwen-max"
  # base_url: "https://dashscope.aliyuncs.com/compatible-mode/v1"
  # api_key: "YOUR_QWEN_API_KEY"

# 项目输出目录
workspace:
  path: "./workspace"

# Devil's Advocate 配置
devil_advocate:
  enabled: true                  # 是否启用反驳 Agent
  max_risks_per_review: 5        # 最多输出几条风险

# Persona 配置
persona:
  num_personas: 3                # 生成几个用户画像
  validation_threshold: 0.6      # Persona 匹配置信度阈值（低于此值触发警告）
